# =============================================================================
# quantum_key_check - Verify a QKD key by *fetching* it from qConnect.
#
# Called from sites-enabled/default { authorize { ... } } before pap.
#
# New model (vs the old stub-based KeyId+Key compare):
#   - Supplicant (server01) calls enc_keys on qConnect, gets (key_id, key).
#   - Supplicant POSTs {username, password, KeyId, MasterSaeId} to its NAS.
#   - NAS forwards Access-Request with Quantum-Key-Id and Quantum-Master-SAE-ID.
#   - This policy invokes /usr/local/bin/quantum-key-check with both VSAs.
#     The helper calls qConnect's dec_keys over mTLS.
#       * Successful retrieval -> "OK"  (we don't compare anything)
#       * Any failure          -> "FAIL:<reason>"
#
# Scope: enforced for both server01 and client01 — each calls enc_keys at
# its own boot/run and ships {key_id, master_sae_id} via VSAs; this policy
# verifies by *fetching* the key from qConnect over mTLS. Legacy users
# (testuser, radius-ui smoke tests) still pass through unchanged.
# =============================================================================
quantum_key_check {
    if (&User-Name == "server01" || &User-Name == "client01") {
        if (!&Quantum-Key-Id || !&Quantum-Master-SAE-ID) {
            update reply {
                Reply-Message := "Quantum VSAs missing (need Key-Id + Master-SAE-ID)"
            }
            reject
        }
        else {
            if ("%{exec:/usr/local/bin/quantum-key-check %{Quantum-Key-Id} %{Quantum-Master-SAE-ID}}" != "OK") {
                update reply {
                    Reply-Message := "Quantum-Key dec_keys retrieval failed"
                }
                reject
            }
        }
    }
}

